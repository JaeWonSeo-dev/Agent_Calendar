# Discord bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=

# Backend API base URL used by the bot
AGENT_CALENDAR_API_BASE_URL=http://127.0.0.1:8000

# Optional: speed up slash-command sync for one guild during development.
DISCORD_GUILD_ID=

# Optional: reserved for future action-threshold tuning.
DISCORD_ACTION_CONFIDENCE=0.62
